use core.process;

mod api;
mod model;
mod services;
mod runtime;
mod cli;
mod tests;
mod util;

fn main() -> i32 {
    let mode = process.argv_or(1, "help")
    if mode == "--help" || mode == "-h" || mode == "help" {
        discard cli.boot()
        return cli.print_help()
    }
    discard runtime.boot()
    discard cli.boot()
    return cli.run(mode)
}
